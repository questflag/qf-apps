@page "/admin/tenants"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "passport_admin,tenant_admin")]

@using QuestFlag.Passport.AdminClient
@inject PassportAdminClient AdminClient

<PageTitle>Tenants â€” Passport Admin</PageTitle>

<div class="max-w-7xl mx-auto p-4 space-y-6">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center">
        <h1 class="text-2xl font-extrabold mb-4 sm:mb-0">Tenants</h1>
        <div class="flex space-x-2">
            <input @bind="_searchQuery" @bind:event="oninput" placeholder="Search tenants..." class="form-control w-auto" />
            <button class="btn btn-primary" @onclick="() => _showCreate = true">+ New Tenant</button>
        </div>
    </div>

    @if (_showCreate)
    {
        <div class="card p-6">
            <h2 class="text-lg font-semibold mb-4">Create Tenant</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                <div><label class="block text-sm font-medium mb-1">Name</label><input @bind="_newName" placeholder="Acme Corp" class="form-control" /></div>
                <div><label class="block text-sm font-medium mb-1">Slug</label><input @bind="_newSlug" placeholder="acme" class="form-control" /></div>
                <div><label class="block text-sm font-medium mb-1">Custom Domain</label><input @bind="_newDomain" placeholder="acme.questflag.com" class="form-control" /></div>
                <div><label class="block text-sm font-medium mb-1">Subdomain Slug</label><input @bind="_newSubSlug" placeholder="acme" class="form-control" /></div>
            </div>
            @if (_createError != null) { <div class="p-3 text-sm border mt-4">@_createError</div> }
            <div class="mt-4 flex space-x-2">
                <button class="btn btn-primary" @onclick="CreateTenant" disabled="@_creating">@(_creating ? "Creatingâ€¦" : "Create")</button>
                <button class="btn btn-secondary" @onclick="() => _showCreate = false">Cancel</button>
            </div>
        </div>
    }

    @if (_editingTenant != null)
    {
        <div class="card p-6">
            <h2 class="text-lg font-semibold mb-4">Edit Tenant: <span >@_editingTenant.Name</span></h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
                <div><label class="block text-sm font-medium mb-1">Name</label><input @bind="_editName" class="form-control" /></div>
                <div><label class="block text-sm font-medium mb-1">Slug</label><input @bind="_editSlug" class="form-control" /></div>
                <div><label class="block text-sm font-medium mb-1">Custom Domain</label><input @bind="_editDomain" class="form-control" /></div>
                <div><label class="block text-sm font-medium mb-1">Subdomain Slug</label><input @bind="_editSubSlug" class="form-control" /></div>
                <div>
                    <label class="block text-sm font-medium mb-1">Status</label>
                    <select @bind="_editIsActive" class="form-control">
                        <option value="true">Active</option>
                        <option value="false">Inactive</option>
                    </select>
                </div>
            </div>
            @if (_editError != null) { <div class="p-3 text-sm border mt-4">@_editError</div> }
            <div class="mt-4 flex space-x-2">
                <button class="btn btn-primary" @onclick="UpdateTenant" disabled="@_updating">@(_updating ? "Savingâ€¦" : "Save Changes")</button>
                <button class="btn btn-secondary" @onclick="() => _editingTenant = null">Cancel</button>
            </div>
        </div>
    }

    @if (_tenants == null)
    {
        <p class="text-sm font-medium">Loading tenantsâ€¦</p>
    }
    else
    {
        <div class="card overflow-x-auto">
            <table class="w-full text-left">
                <thead class="table-header"><tr><th class="px-4 py-3">Name</th><th class="px-4 py-3">Slug</th><th class="px-4 py-3">Custom Domain</th><th class="px-4 py-3">Status</th><th class="px-4 py-3">Actions</th></tr></thead>
                <tbody >
                @foreach (var t in FilteredTenants ?? Array.Empty<TenantAdminDto>())
                {
                    <tr class="hover: transition-colors">
                        <td class="table-cell"><a href="/admin/tenants/@t.Id/users" class="text-primary font-medium">@t.Name</a></td>
                        <td class="table-cell"><code class="text-xs px-1.5 py-0.5 rounded">@t.Slug</code></td>
                        <td class="table-cell">@(t.CustomDomain ?? t.SubdomainSlug ?? "â€”")</td>
                        <td class="table-cell"><span class="badge @(t.IsActive ?"badge-success" : "badge-default")">@(t.IsActive ? "Active" : "Inactive")</span></td>
                        <td class="table-cell">
                            <div class="flex items-center gap-2">
                                <a href="/admin/tenants/@t.Id/users" class="text-sm font-medium text-primary hover:text-primary-hover transition-colors">Users</a>
                                <button class="text-sm font-medium hover:" @onclick="() => StartEdit(t)">Edit</button>
                                <button class="text-sm font-medium hover:" @onclick="() => DeleteTenant(t.Id)">Delete</button>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>

