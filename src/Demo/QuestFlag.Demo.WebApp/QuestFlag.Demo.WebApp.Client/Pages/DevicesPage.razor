@page "/admin/users/{UserId:guid}/devices"

@using QuestFlag.Passport.AdminClient
@inject PassportAdminClient AdminClient

<PageTitle>Devices â€” Passport Admin</PageTitle>

<div class="max-w-7xl mx-auto p-4 space-y-6">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center">
        <h1 class="text-2xl font-extrabold mb-4 sm:mb-0">Trusted Devices</h1>
        <button class="btn btn-danger" @onclick="RevokeAll">Revoke All</button>
    </div>

    @if (_devices == null) { <p class="text-sm font-medium">Loading devicesâ€¦</p> }
    else if (_devices.Count == 0) {
        <div class="card p-12 flex flex-col items-center justify-center text-center">
            <span class="bi bi-laptop text-4xl mb-3" aria-hidden="true"></span>
            <p class="text-sm font-medium">No trusted devices.</p>
        </div>
    }
    else
    {
        <div class="card overflow-x-auto">
            <table class="w-full text-left">
                <thead class="table-header"><tr><th class="px-4 py-3">Device</th><th class="px-4 py-3">IP</th><th class="px-4 py-3">Trusted At</th><th class="px-4 py-3">Expires</th><th class="px-4 py-3 text-right">Actions</th></tr></thead>
                <tbody >
                @foreach (var d in _devices)
                {
                    <tr class="hover: transition-colors">
                        <td class="table-cell font-medium">
                            <div class="flex items-center">
                                <span class="bi bi-laptop mr-2 text-primary" aria-hidden="true"></span>
                                @d.DeviceName
                            </div>
                        </td>
                        <td class="table-cell"><code>@d.IpAddress</code></td>
                        <td class="table-cell">@d.TrustedAtUtc.ToLocalTime().ToString("g")</td>
                        <td class="table-cell">@d.ExpiresAtUtc.ToLocalTime().ToString("g")</td>
                        <td class="table-cell text-right"><button class="btn btn-danger !px-2 !py-1 !text-xs !h-auto" @onclick="() => RevokeDevice(d.Id)">Revoke</button></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>

