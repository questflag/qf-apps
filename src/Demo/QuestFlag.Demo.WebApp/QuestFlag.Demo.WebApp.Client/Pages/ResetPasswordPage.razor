@page "/reset-password"

@using QuestFlag.Passport.UserClient
@inject PassportUserClient PassportClient
@inject NavigationManager Nav

<PageTitle>Reset Password — QuestFlag</PageTitle>

<div class="flex items-center justify-center min-h-[calc(100vh-8rem)] bg-white px-4 sm:px-6 lg:px-8">
    <div class="w-full max-w-md space-y-8 card p-8">
        <div class="text-center">
            <div class="mx-auto h-12 w-12 bg-primary text-white rounded-lg flex items-center justify-center text-xl font-bold mb-4 shadow-sm">QF</div>
            <h1 class="text-3xl font-extrabold tracking-tight text-gray-900">Reset Password</h1>
            <p class="mt-2 text-sm text-gray-500">Enter your new password</p>
        </div>

        @if (_success)
        {
            <div class="rounded-md bg-green-50 p-4 border border-green-200">
                <div class="flex">
                    <div class="ml-3">
                        <p class="text-sm font-medium text-green-800">
                            ✓ Password reset successfully. You can now sign in.
                        </p>
                    </div>
                </div>
            </div>
            <div class="text-center mt-4">
                <a href="/login" class="text-sm font-medium text-primary hover:text-primary-hover transition-colors">Sign In</a>
            </div>
        }
        else
        {
            @if (_error != null)
            {
                <div class="rounded-md bg-red-50 p-4 border border-red-200">
                    <div class="flex">
                        <div class="ml-3">
                            <h3 class="text-sm font-medium text-red-800">Error</h3>
                            <div class="mt-2 text-sm text-red-700">
                                <p>@_error</p>
                            </div>
                        </div>
                    </div>
                </div>
            }
            <form @onsubmit="HandleReset" class="mt-8 space-y-6">
                <div class="space-y-4 rounded-md shadow-sm">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">New Password</label>
                        <input @bind="_password" type="password" placeholder="••••••••" required class="input-field" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Confirm Password</label>
                        <input @bind="_confirm" type="password" placeholder="••••••••" required class="input-field" />
                    </div>
                </div>
                <div class="pt-2">
                    <button type="submit" disabled="@_isSubmitting" class="btn btn-primary w-full shadow-sm text-base py-3 h-12">
                        @(_isSubmitting ? "Resetting…" : "Reset Password")
                    </button>
                </div>
            </form>
        }
    </div>
</div>
