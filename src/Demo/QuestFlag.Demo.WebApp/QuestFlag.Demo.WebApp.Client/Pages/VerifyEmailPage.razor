@page "/verify-email"

@using QuestFlag.Passport.UserClient
@inject PassportUserClient PassportClient
@inject NavigationManager Nav

<PageTitle>Verify Email â€” QuestFlag</PageTitle>

<div class="flex items-center justify-center min-h-[calc(100vh-8rem)] bg-white px-4 sm:px-6 lg:px-8">
    <div class="w-full max-w-md space-y-8 bg-white p-8 rounded-xl border">
        <div class="text-center">
            <div class="mx-auto h-12 w-12 bg-primary text-white rounded-lg flex items-center justify-center text-xl font-bold mb-4">QF</div>
            <h1 class="text-3xl font-extrabold">Accept Invitation</h1>
            <p class="mt-2 text-sm">Set your password to activate your account</p>
        </div>

        @if (_success)
        {
            <div class="p-4 border">
                <div class="flex">
                    <div class="ml-3">
                        <p class="text-sm font-medium">
                            âœ“ Account activated! You can now sign in.
                        </p>
                    </div>
                </div>
            </div>
            <div class="text-center mt-4">
                <a href="/login" class="text-sm font-medium text-primary hover:text-primary-hover transition-colors">Sign In</a>
            </div>
        }
        else
        {
            @if (_error != null)
            {
                <div class="p-4 border">
                    <div class="flex">
                        <div class="ml-3">
                            <h3 class="text-sm font-medium">Error</h3>
                            <div class="mt-2 text-sm">
                                <p>@_error</p>
                            </div>
                        </div>
                    </div>
                </div>
            }
            <form @onsubmit="HandleVerify" class="mt-8 space-y-6">
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium mb-1">Password</label>
                        <input @bind="_password" type="password" placeholder="Create a password" required class="relative block w-full py-2.5 ring-1 ring-inset ring-gray-300 placeholder: focus:z-10 focus:ring-2 focus:ring-inset focus:ring-primary sm:text-sm sm:leading-6 transition-colors" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-1">Confirm Password</label>
                        <input @bind="_confirm" type="password" placeholder="â€¢â€¢â€¢â€¢â€¢â€¢â€¢â€¢" required class="relative block w-full py-2.5 ring-1 ring-inset ring-gray-300 placeholder: focus:z-10 focus:ring-2 focus:ring-inset focus:ring-primary sm:text-sm sm:leading-6 transition-colors" />
                    </div>
                </div>
                <div>
                    <button type="submit" disabled="@_isSubmitting" class="group relative flex w-full justify-center bg-primary px-3 py-2.5 text-sm font-semibold text-white hover:bg-primary-hover focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary disabled:opacity-70 disabled:cursor-not-allowed transition-all duration-200">
                        @(_isSubmitting ? "Activatingâ€¦" : "Activate Account")
                    </button>
                </div>
            </form>
        }
    </div>
</div>

