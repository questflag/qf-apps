@page "/admin/agents"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "passport_admin,tenant_admin")]

@using QuestFlag.Passport.AdminClient
@inject PassportAdminClient AdminClient
@inject IJSRuntime JSRuntime

<PageTitle>Agents â€” Passport Admin</PageTitle>

<div class="max-w-7xl mx-auto p-4 space-y-6">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center">
        <h1 class="text-2xl font-extrabold mb-4 sm:mb-0">Agents (Apps)</h1>
        <div class="flex space-x-2">
            <input @bind="_searchQuery" @bind:event="oninput" placeholder="Search agents..." class="form-control w-auto" />
            <button class="btn btn-primary" @onclick="() => _showCreate = true">+ New Agent</button>
        </div>
    </div>

    @if (_showCreate)
    {
        <div class="card p-6">
            <h2 class="text-lg font-semibold mb-4">Create Agent</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div><label class="block text-sm font-medium mb-1">Client ID</label><input @bind="_newClientId" placeholder="my-app" class="form-control" /></div>
                <div><label class="block text-sm font-medium mb-1">Display Name</label><input @bind="_newDisplayName" placeholder="My Application" class="form-control" /></div>
                <div><label class="block text-sm font-medium mb-1">Client Secret (Optional)</label><input @bind="_newSecret" type="password" class="form-control" /></div>
                <div>
                    <label class="block text-sm font-medium mb-1">Type</label>
                    <select @bind="_newType" class="form-control">
                        <option value="public">Public (SPA/Mobile)</option>
                        <option value="confidential">Confidential (Server-side)</option>
                    </select>
                </div>
            </div>
            @if (_createError != null) { <div class="p-3 text-sm border mt-4">@_createError</div> }
            <div class="mt-4 flex space-x-2">
                <button class="btn btn-primary" @onclick="CreateAgent" disabled="@_creating">@(_creating ? "Creatingâ€¦" : "Create")</button>
                <button class="btn btn-secondary" @onclick="() => _showCreate = false">Cancel</button>
            </div>
        </div>
    }

    @if (_editingAgent != null)
    {
        <div class="card p-6">
            <h2 class="text-lg font-semibold mb-4">Edit Agent: <span >@_editingAgent.ClientId</span></h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div><label class="block text-sm font-medium mb-1">Display Name</label><input @bind="_editDisplayName" class="form-control" /></div>
                <div>
                    <label class="block text-sm font-medium mb-1">Type</label>
                    <select @bind="_editType" class="form-control">
                        <option value="public">Public</option>
                        <option value="confidential">Confidential</option>
                    </select>
                </div>
                <div class="col-span-2">
                    <label class="block text-sm font-medium mb-1">Redirect URIs (comma separated)</label>
                    <textarea @bind="_editRedirectUris" class="form-control h-20" placeholder="https://localhost:7000/callback"></textarea>
                </div>
            </div>
            @if (_editError != null) { <div class="p-3 text-sm border mt-4">@_editError</div> }
            <div class="mt-4 flex space-x-2">
                <button class="btn btn-primary" @onclick="UpdateAgent" disabled="@_updating">@(_updating ? "Savingâ€¦" : "Save Changes")</button>
                <button class="btn btn-secondary" @onclick="() => _editingAgent = null">Cancel</button>
            </div>
        </div>
    }

    @if (_agents == null) { <p class="text-sm font-medium">Loading agentsâ€¦</p> }
    else
    {
        <div class="card overflow-x-auto">
            <table class="w-full text-left">
                <thead class="table-header"><tr><th class="px-4 py-3">Client ID</th><th class="px-4 py-3">Display Name</th><th class="px-4 py-3">Type</th><th class="px-4 py-3">Actions</th></tr></thead>
                <tbody >
                @foreach (var a in FilteredAgents)
                {
                    <tr class="hover: transition-colors">
                        <td class="table-cell"><code class="text-xs px-1.5 py-0.5 rounded">@a.ClientId</code></td>
                        <td class="table-cell font-medium">@a.DisplayName</td>
                        <td class="table-cell"><span class="badge @(a.Type =="public" ? "badge-default" : "badge-success")">@a.Type</span></td>
                        <td class="table-cell">
                            <div class="flex items-center gap-2">
                                <button class="text-sm font-medium hover:" @onclick="() => StartEdit(a)">Edit</button>
                                <button class="text-sm font-medium hover:" @onclick="() => DeleteAgent(a.ClientId)">Delete</button>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>

