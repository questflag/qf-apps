@page "/admin/tenants/{TenantId:guid}/users"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "passport_admin,tenant_admin")]

@using QuestFlag.Passport.AdminClient
@inject PassportAdminClient AdminClient

<PageTitle>Users — Passport Admin</PageTitle>

<div class="max-w-7xl mx-auto p-4 space-y-6">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center">
        <div class="flex flex-col">
            <a href="/admin/tenants" class="text-xs font-medium text-gray-500 hover:text-primary mb-1">← Back to Tenants</a>
            <h1 class="text-2xl font-extrabold tracking-tight text-gray-900">Users</h1>
        </div>
        <div class="flex space-x-2 mt-4 sm:mt-0">
            <input @bind="SearchQuery" @bind:event="oninput" placeholder="Search users..." class="input-field w-64" />
            <button class="btn btn-primary" @onclick="PrepareInvite">✉ Invite User</button>
        </div>
    </div>

    @if (_showInvite)
    {
        <div class="card p-6 bg-blue-50/30 border-blue-100">
            <h2 class="text-lg font-semibold mb-4">Invite User <span class="text-sm font-normal text-gray-500">(sends an email to set their password)</span></h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                <div><label class="block text-sm font-medium text-gray-700 mb-1">Username</label><input @bind="_invUsername" placeholder="jane.doe" class="input-field" /></div>
                <div><label class="block text-sm font-medium text-gray-700 mb-1">Email</label><input @bind="_invEmail" type="email" placeholder="jane@acme.com" class="input-field" /></div>
                <div><label class="block text-sm font-medium text-gray-700 mb-1">Display Name</label><input @bind="_invDisplayName" placeholder="Jane Doe" class="input-field" /></div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Roles</label>
                    <div class="space-y-1 max-h-32 overflow-y-auto border rounded p-2 bg-white">
                        @if (_availableRoles != null)
                        {
                            foreach (var r in _availableRoles)
                            {
                                <label class="flex items-center space-x-2 text-sm text-gray-700">
                                    <input type="checkbox" checked="@_invRoles.Contains(r.Name)" 
                                           @onchange="@(e => { if((bool)e.Value!) _invRoles.Add(r.Name); else _invRoles.Remove(r.Name); })" />
                                    <span>@r.Name</span>
                                </label>
                            }
                        }
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Agents (Assign access)</label>
                    <div class="space-y-1 max-h-32 overflow-y-auto border rounded p-2 bg-white">
                        @if (_availableAgents != null)
                        {
                            foreach (var a in _availableAgents)
                            {
                                <label class="flex items-center space-x-2 text-sm text-gray-700">
                                    <input type="checkbox" checked="@_invAgentClientIds.Contains(a.ClientId)" 
                                           @onchange="@(e => { if((bool)e.Value!) _invAgentClientIds.Add(a.ClientId); else _invAgentClientIds.Remove(a.ClientId); })" />
                                    <span>@a.DisplayName</span>
                                </label>
                            }
                        }
                    </div>
                </div>
            </div>
            @if (_inviteError != null) { <div class="bg-red-50 text-red-600 p-3 rounded-md text-sm border border-red-200 mt-4">@_inviteError</div> }
            @if (_inviteSent) { <div class="bg-green-50 text-green-700 p-3 rounded-md text-sm border border-green-200 mt-4">✓ Invite sent to @_invEmail</div> }
            <div class="mt-4 flex space-x-2">
                <button class="btn btn-primary" @onclick="InviteUser" disabled="@_inviting">@(_inviting ? "Sending…" : "Send Invite")</button>
                <button class="btn btn-secondary" @onclick="() => _showInvite = false">Cancel</button>
            </div>
        </div>
    }

    @if (_editingUser != null)
    {
        <div class="card p-6 bg-amber-50/30 border-amber-100">
            <h2 class="text-lg font-semibold mb-4">Edit User: <span class="text-amber-700">@_editingUser.DisplayName</span></h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
                <div><label class="block text-sm font-medium text-gray-700 mb-1">Username</label><input @bind="_editUsername" class="input-field" /></div>
                <div><label class="block text-sm font-medium text-gray-700 mb-1">Email</label><input @bind="_editEmail" class="input-field" /></div>
                <div><label class="block text-sm font-medium text-gray-700 mb-1">Display Name</label><input @bind="_editDisplayName" class="input-field" /></div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Roles</label>
                    <div class="space-y-1 max-h-32 overflow-y-auto border rounded p-2 bg-white">
                        @if (_availableRoles != null)
                        {
                            foreach (var r in _availableRoles)
                            {
                                <label class="flex items-center space-x-2 text-sm text-gray-700">
                                    <input type="checkbox" checked="@_editRoles.Contains(r.Name)" 
                                           @onchange="@(e => { if((bool)e.Value!) _editRoles.Add(r.Name); else _editRoles.Remove(r.Name); })" />
                                    <span>@r.Name</span>
                                </label>
                            }
                        }
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Agents</label>
                    <div class="space-y-1 max-h-32 overflow-y-auto border rounded p-2 bg-white">
                        @if (_availableAgents != null)
                        {
                            foreach (var a in _availableAgents)
                            {
                                <label class="flex items-center space-x-2 text-sm text-gray-700">
                                    <input type="checkbox" checked="@_editAgentClientIds.Contains(a.ClientId)" 
                                           @onchange="@(e => { if((bool)e.Value!) _editAgentClientIds.Add(a.ClientId); else _editAgentClientIds.Remove(a.ClientId); })" />
                                    <span>@a.DisplayName</span>
                                </label>
                            }
                        }
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
                    <select @bind="_editIsActive" class="input-field">
                        <option value="true">Active</option>
                        <option value="false">Inactive</option>
                    </select>
                </div>
            </div>
            @if (_editError != null) { <div class="bg-red-50 text-red-600 p-3 rounded-md text-sm border border-red-200 mt-4">@_editError</div> }
            <div class="mt-4 flex space-x-2">
                <button class="btn btn-primary" @onclick="UpdateUser" disabled="@_updating">@(_updating ? "Saving…" : "Save Changes")</button>
                <button class="btn btn-secondary" @onclick="() => _editingUser = null">Cancel</button>
            </div>
        </div>
    }

    @if (_users == null) { <p class="text-sm font-medium text-gray-500">Loading users…</p> }
    else
    {
        <div class="card overflow-x-auto">
            <table class="w-full text-left">
                <thead class="table-header"><tr><th class="px-4 py-3">Name</th><th class="px-4 py-3">Username</th><th class="px-4 py-3">Email</th><th class="px-4 py-3">Role</th><th class="px-4 py-3">2FA</th><th class="px-4 py-3">Status</th><th class="px-4 py-3">Actions</th></tr></thead>
                <tbody class="divide-y divide-gray-100">
                @foreach (var u in FilteredUsers ?? Array.Empty<UserAdminDto>())
                {
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="table-cell font-medium text-gray-900">@u.DisplayName</td>
                        <td class="table-cell"><code class="text-xs bg-gray-100 text-gray-800 px-1.5 py-0.5 rounded">@u.Username</code></td>
                        <td class="table-cell">
                            <div class="flex items-center space-x-1">
                                <span>@u.Email</span>
                                @if (u.EmailConfirmed) { <span class="text-green-600 font-bold" title="Confirmed">✓</span> } else { <span class="text-yellow-600" title="Pending">⏳</span> }
                            </div>
                        </td>
                        <td class="table-cell">
                            <div class="flex flex-wrap gap-1">
                                @foreach (var role in u.Roles ?? new List<string>())
                                {
                                    <span class="badge badge-default">@role</span>
                                }
                            </div>
                        </td>
                        <td class="table-cell">
                            @if (u.TwoFactorEnabled) { <span class="inline-flex items-center space-x-1 text-green-700"><span class="font-bold">✓</span><span>On</span></span> } else { <span class="text-gray-500">Off</span> }
                        </td>
                        <td class="table-cell"><span class="badge @(u.IsActive ? "badge-success" : "badge-default")">@(u.IsActive ? "Active" : "Inactive")</span></td>
                        <td class="table-cell">
                            <div class="flex flex-wrap items-center gap-2">
                                <a href="/admin/users/@u.Id/devices" class="text-sm font-medium text-primary hover:text-primary-hover transition-colors">Devices</a>
                                <button class="text-sm font-medium text-amber-600 hover:text-amber-700" @onclick="() => StartEdit(u)">Edit</button>
                                <button class="text-sm font-medium text-red-600 hover:text-red-700" @onclick="() => DeleteUser(u.Id)">Delete</button>
                                <button class="btn btn-danger !px-2 !py-1 !text-xs !h-auto" @onclick="() => ForceLogout(u.Id)">Force Logout</button>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
