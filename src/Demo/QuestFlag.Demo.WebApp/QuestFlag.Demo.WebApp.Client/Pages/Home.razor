@page "/"

<PageTitle>QuestFlag — Infrastructure Management</PageTitle>

<div class="relative py-12 px-6 sm:py-24 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
        <div class="inline-flex items-center px-4 py-1.5 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-widest mb-8 border border-primary/20">
            <span class="mr-2 h-2 w-2 rounded-full bg-primary animate-pulse"></span>
            Cloud Infrastructure Ecosystem
        </div>
        
        <h1 class="text-5xl font-black text-slate-900 tracking-tight sm:text-7xl mb-6">
            Manage your <span class="text-primary italic">Entire Fleet</span> from one place.
        </h1>
        
        <p class="text-lg leading-8 text-slate-500 font-medium mb-12">
            The next-generation platform for infrastructure automation, agent management, 
            and secure communication. Scalable, resilient, and ready for the future.
        </p>
        
        <div class="flex items-center justify-center gap-x-6">
            <a href="/login" class="group relative px-8 py-4 bg-primary text-white rounded-2xl text-sm font-black uppercase tracking-widest shadow-premium hover:bg-primary-hover transition-all duration-300 transform hover:-translate-y-1">
                Sign In to Platform
                <span class="bi bi-arrow-right ml-2 group-hover:translate-x-1 transition-transform inline-block"></span>
            </a>
            
            <a href="https://questflag.com" class="text-sm font-black text-slate-400 hover:text-slate-900 uppercase tracking-widest transition-colors">
                Learn More
            </a>
        </div>
    </div>
    
    <!-- Decorative background elements -->
    <div class="absolute top-0 left-1/2 -z-10 -translate-x-1/2 blur-3xl" aria-hidden="true">
        <div class="aspect-[1155/678] w-[72.1875rem] bg-gradient-to-tr from-primary to-primary-hover opacity-10"></div>
    </div>
</div>
