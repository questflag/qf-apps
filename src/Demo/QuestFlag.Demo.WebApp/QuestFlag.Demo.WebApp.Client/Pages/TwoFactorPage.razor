@page "/login/two-factor"

@using QuestFlag.Passport.UserClient
@inject PassportUserClient PassportClient
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Two-Factor Authentication — QuestFlag</PageTitle>

<div class="flex items-center justify-center min-h-[calc(100vh-8rem)] bg-white px-4 sm:px-6 lg:px-8">
    <div class="w-full max-w-md space-y-8 card p-8">
        <div class="text-center">
            <div class="mx-auto h-12 w-12 bg-primary text-white rounded-lg flex items-center justify-center text-xl font-bold mb-4 shadow-sm">QF</div>
            <h1 class="text-3xl font-extrabold tracking-tight text-gray-900">Verify It's You</h1>
            <p class="mt-2 text-sm text-gray-500">Enter the 6-digit code sent to your phone</p>
        </div>

        @if (_error != null)
        {
            <div class="rounded-md bg-red-50 p-4 border border-red-200">
                <div class="flex">
                    <div class="ml-3">
                        <h3 class="text-sm font-medium text-red-800">Error</h3>
                        <div class="mt-2 text-sm text-red-700">
                            <p>@_error</p>
                        </div>
                    </div>
                </div>
            </div>
        }

        <form @onsubmit="HandleVerify" class="mt-8 space-y-6">
            <div class="space-y-4 rounded-md shadow-sm">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Verification Code</label>
                    <input @bind="_otp" type="text" inputmode="numeric" pattern="[0-9]*"
                           maxlength="6" placeholder="000000" autocomplete="one-time-code" required class="input-field text-center tracking-[0.5em] text-xl font-bold placeholder:tracking-normal placeholder:font-normal h-14" />
                </div>
            </div>

            <div class="flex items-center justify-between">
                <div class="flex items-center">
                    <input id="rememberDevice" name="rememberDevice" type="checkbox" @bind="_rememberDevice" class="h-4 w-4 rounded border-gray-300 text-primary focus:ring-primary" />
                    <label for="rememberDevice" class="ml-2 block text-sm text-gray-900">Trust this device for 30 days</label>
                </div>
            </div>

            <div class="pt-2">
                <button type="submit" disabled="@_isSubmitting" class="btn btn-primary w-full shadow-sm text-base py-3 h-12">
                    @(_isSubmitting ? "Verifying…" : "Verify")
                </button>
            </div>
        </form>

        <div class="text-center mt-4">
            <a href="/login" class="text-sm font-medium text-gray-500 hover:text-gray-700 transition-colors">← Back to Sign In</a>
            <span class="mx-2 text-gray-300">|</span>
            <a @onclick="ResendOtp" href="javascript:void(0)" class="text-sm font-medium text-primary hover:text-primary-hover transition-colors">Resend code</a>
        </div>
    </div>
</div>
