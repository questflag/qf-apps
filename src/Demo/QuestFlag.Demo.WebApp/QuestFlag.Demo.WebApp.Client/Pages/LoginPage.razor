@page "/login"
@page "/sso"
@page "/account/login"
@rendermode InteractiveAuto
@inject NavigationManager Nav
@inject IConfiguration Configuration
@inject IJSRuntime JS
@using QuestFlag.Demo.WebApp.Client.Helpers

<PageTitle>Sign In — QuestFlag</PageTitle>

<div class="flex items-center justify-center min-h-screen bg-white">
    <!-- Animated background element -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute -top-[10%] -left-[10%] w-[40%] h-[40%] rounded-full bg-primary/5 blur-[120px] animate-pulse"></div>
        <div class="absolute -bottom-[10%] -right-[10%] w-[40%] h-[40%] rounded-full bg-primary/5 blur-[120px] animate-pulse" style="animation-delay: 2s;"></div>
    </div>

    <div class="relative w-full max-w-md p-10 text-center">
        <!-- Brand Logo -->
        <div class="inline-flex items-center justify-center w-20 h-20 rounded-3xl bg-primary text-white text-3xl font-black shadow-premium mb-10 transform hover:scale-105 transition-transform duration-500">
            QF
        </div>

        <!-- Content -->
        <div class="space-y-4">
            <h1 class="text-3xl font-black text-slate-900 tracking-tighter">Authenticating</h1>
            <p class="text-slate-400 font-semibold uppercase tracking-[0.2em] text-[10px]">Preparing your secure session</p>
            
            <div class="pt-10 flex flex-col items-center">
                <div class="flex space-x-2 mb-10">
                    <div class="w-2 h-2 rounded-full bg-primary animate-bounce"></div>
                    <div class="w-2 h-2 rounded-full bg-primary animate-bounce [animation-delay:0.2s]"></div>
                    <div class="w-2 h-2 rounded-full bg-primary animate-bounce [animation-delay:0.4s]"></div>
                </div>

                <button @onclick="RedirectToSso" class="group relative px-8 py-4 bg-slate-50 hover:bg-slate-100 text-slate-400 hover:text-slate-600 rounded-2xl text-xs font-black uppercase tracking-widest transition-all duration-300">
                    Click here if not redirected
                </button>
            </div>
        </div>
    </div>
</div>

