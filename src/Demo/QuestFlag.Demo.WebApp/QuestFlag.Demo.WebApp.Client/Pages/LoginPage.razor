@page "/login"
@page "/sso"
@rendermode InteractiveAuto
@using QuestFlag.Passport.UserClient
@inject PassportUserClient PassportClient
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Sign In — @(_resolvedTenant?.Name ?? "QuestFlag")</PageTitle>

<div class="flex items-center justify-center min-h-[calc(100vh-8rem)] bg-white px-4 sm:px-6 lg:px-8">
    <div class="w-full max-w-md space-y-8 card p-8 text-center animate-pulse">
        <div class="mx-auto h-12 w-12 bg-primary text-white rounded-lg flex items-center justify-center text-xl font-bold mb-4 shadow-sm">QF</div>
        <h1 class="text-3xl font-extrabold tracking-tight text-gray-900">Redirecting...</h1>
        <p class="mt-2 text-sm text-gray-500 font-medium">We're taking you to the secure login portal.</p>
        
        <div class="pt-8">
            <a href="account/login" class="btn btn-primary w-full shadow-sm text-base py-3 h-12">
                Click here if not redirected
            </a>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        Nav.NavigateTo("account/login", forceLoad: true);
    }
}
