@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

<div class="min-h-screen flex flex-col justify-center items-center bg-white">
    <div class="max-w-md w-full space-y-8 p-10 bg-white rounded-2xl shadow-premium border border-gray-100">
        <div class="text-center">
            <h1 class="text-4xl font-extrabold tracking-tight text-gray-900 mb-2">QuestFlag</h1>
            <p class="text-sm text-gray-500 font-medium">Infrastructure Management Platform</p>
        </div>
        
        <div class="mt-8 space-y-6">
            @if (NavigationManager.ToAbsoluteUri(NavigationManager.Uri).AbsolutePath.TrimEnd('/').EndsWith("/login") || 
                 NavigationManager.ToAbsoluteUri(NavigationManager.Uri).AbsolutePath.TrimEnd('/').EndsWith("/sso"))
            {
                @Body
            }
            else
            {
                <div class="text-center">
                    <p class="text-gray-600 mb-8">Welcome! Please sign in to access the infrastructure dashboard.</p>
                    <a href="account/login" class="inline-flex items-center justify-center px-8 py-3 border border-transparent text-base font-bold rounded-xl text-white bg-primary hover:bg-primary-dark transition-all transform hover:scale-105 shadow-premium">
                        Login to Continue
                    </a>
                </div>
            }
        </div>
        
        <div class="mt-8 pt-8 border-t border-gray-100 text-center text-xs text-gray-400 font-bold uppercase tracking-widest">
            &copy; @DateTime.Now.Year QuestFlag Infrastructure
        </div>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet class="fixed bottom-0 left-0 right-0 z-50 hidden bg-red-50 p-4 border-t border-red-200">
    <div class="flex items-center justify-between max-w-7xl mx-auto">
        <span class="text-sm text-red-800">An unhandled error has occurred.</span>
        <div class="flex space-x-4">
            <a href="." class="reload text-sm font-medium text-red-600 hover:text-red-500">Reload</a>
            <button class="dismiss text-red-400 hover:text-red-500">
                <span class="sr-only">Dismiss</span>
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    </div>
</div>
