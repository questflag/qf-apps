@page "/admin/agents"
@using QuestFlag.Passport.AdminClient
@inject PassportAdminClient AdminClient
@inject IJSRuntime JSRuntime

<PageTitle>Agents — Passport Admin</PageTitle>

<div class="max-w-7xl mx-auto p-4 space-y-6">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center">
        <h1 class="text-2xl font-extrabold tracking-tight text-gray-900 mb-4 sm:mb-0">Agents (Apps)</h1>
        <div class="flex space-x-2">
            <input @bind="_searchQuery" @bind:event="oninput" placeholder="Search agents..." class="input-field w-64" />
            <button class="btn btn-primary" @onclick="() => _showCreate = true">+ New Agent</button>
        </div>
    </div>

    @if (_showCreate)
    {
        <div class="card p-6 bg-blue-50/30 border-blue-100">
            <h2 class="text-lg font-semibold mb-4">Create Agent</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div><label class="block text-sm font-medium text-gray-700 mb-1">Client ID</label><input @bind="_newClientId" placeholder="my-app" class="input-field" /></div>
                <div><label class="block text-sm font-medium text-gray-700 mb-1">Display Name</label><input @bind="_newDisplayName" placeholder="My Application" class="input-field" /></div>
                <div><label class="block text-sm font-medium text-gray-700 mb-1">Client Secret (Optional)</label><input @bind="_newSecret" type="password" class="input-field" /></div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Type</label>
                    <select @bind="_newType" class="input-field">
                        <option value="public">Public (SPA/Mobile)</option>
                        <option value="confidential">Confidential (Server-side)</option>
                    </select>
                </div>
            </div>
            @if (_createError != null) { <div class="bg-red-50 text-red-600 p-3 rounded-md text-sm border border-red-200 mt-4">@_createError</div> }
            <div class="mt-4 flex space-x-2">
                <button class="btn btn-primary" @onclick="CreateAgent" disabled="@_creating">@(_creating ? "Creating…" : "Create")</button>
                <button class="btn btn-secondary" @onclick="() => _showCreate = false">Cancel</button>
            </div>
        </div>
    }

    @if (_editingAgent != null)
    {
        <div class="card p-6 bg-amber-50/30 border-amber-100">
            <h2 class="text-lg font-semibold mb-4">Edit Agent: <span class="text-amber-700">@_editingAgent.ClientId</span></h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div><label class="block text-sm font-medium text-gray-700 mb-1">Display Name</label><input @bind="_editDisplayName" class="input-field" /></div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Type</label>
                    <select @bind="_editType" class="input-field">
                        <option value="public">Public</option>
                        <option value="confidential">Confidential</option>
                    </select>
                </div>
                <div class="col-span-2">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Redirect URIs (comma separated)</label>
                    <textarea @bind="_editRedirectUris" class="input-field h-20" placeholder="https://localhost:7000/callback"></textarea>
                </div>
            </div>
            @if (_editError != null) { <div class="bg-red-50 text-red-600 p-3 rounded-md text-sm border border-red-200 mt-4">@_editError</div> }
            <div class="mt-4 flex space-x-2">
                <button class="btn btn-primary" @onclick="UpdateAgent" disabled="@_updating">@(_updating ? "Saving…" : "Save Changes")</button>
                <button class="btn btn-secondary" @onclick="() => _editingAgent = null">Cancel</button>
            </div>
        </div>
    }

    @if (_agents == null) { <p class="text-sm font-medium text-gray-500">Loading agents…</p> }
    else
    {
        <div class="card overflow-x-auto">
            <table class="w-full text-left">
                <thead class="table-header"><tr><th class="px-4 py-3">Client ID</th><th class="px-4 py-3">Display Name</th><th class="px-4 py-3">Type</th><th class="px-4 py-3">Actions</th></tr></thead>
                <tbody class="divide-y divide-gray-100">
                @foreach (var a in FilteredAgents)
                {
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="table-cell"><code class="text-xs bg-gray-100 text-gray-800 px-1.5 py-0.5 rounded">@a.ClientId</code></td>
                        <td class="table-cell font-medium text-gray-900">@a.DisplayName</td>
                        <td class="table-cell"><span class="badge @(a.Type == "public" ? "badge-default" : "badge-success")">@a.Type</span></td>
                        <td class="table-cell">
                            <div class="flex items-center space-x-3">
                                <button class="text-sm font-medium text-amber-600 hover:text-amber-700" @onclick="() => StartEdit(a)">Edit</button>
                                <button class="text-sm font-medium text-red-600 hover:text-red-700" @onclick="() => DeleteAgent(a.ClientId)">Delete</button>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private IReadOnlyList<AgentDto>? _agents;
    private string _searchQuery = "";
    private bool _showCreate;
    private bool _creating, _updating;
    private string? _createError, _editError;

    private string _newClientId = "", _newDisplayName = "", _newSecret = "", _newType = "public";
    
    private AgentDto? _editingAgent;
    private string _editDisplayName = "", _editType = "", _editRedirectUris = "";

    private IEnumerable<AgentDto> FilteredAgents => 
        string.IsNullOrWhiteSpace(_searchQuery) 
            ? (_agents ?? Array.Empty<AgentDto>()) 
            : (_agents?.Where(a => a.ClientId.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase) || a.DisplayName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase)) ?? Array.Empty<AgentDto>());

    protected override async Task OnInitializedAsync() => await LoadAgentsAsync();

    private async Task LoadAgentsAsync() => _agents = await AdminClient.GetAgentsAsync();

    private async Task CreateAgent()
    {
        _creating = true; _createError = null;
        try {
            await AdminClient.CreateAgentAsync(new CreateAgentRequest(
                _newClientId, _newDisplayName, string.IsNullOrWhiteSpace(_newSecret) ? null : _newSecret, _newType,
                new HashSet<string>(), new HashSet<Uri>(), new HashSet<Uri>()));
            _showCreate = false;
            await LoadAgentsAsync();
        } catch (Exception ex) { _createError = ex.Message; }
        finally { _creating = false; }
    }

    private void StartEdit(AgentDto a)
    {
        _editingAgent = a;
        _editDisplayName = a.DisplayName;
        _editType = a.Type;
        _editRedirectUris = string.Join(", ", a.RedirectUris);
        _editError = null;
    }

    private async Task UpdateAgent()
    {
        if (_editingAgent == null) return;
        _updating = true; _editError = null;
        try {
            var uris = _editRedirectUris.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(u => new Uri(u.Trim())).ToHashSet();
            await AdminClient.UpdateAgentAsync(_editingAgent.ClientId, new UpdateAgentRequest(
                _editingAgent.ClientId, _editDisplayName, null, _editType,
                _editingAgent.Permissions, uris, _editingAgent.PostLogoutRedirectUris));
            _editingAgent = null;
            await LoadAgentsAsync();
        } catch (Exception ex) { _editError = ex.Message; }
        finally { _updating = false; }
    }

    private async Task DeleteAgent(string clientId)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", $"Delete agent {clientId}?")) return;
        await AdminClient.DeleteAgentAsync(clientId);
        await LoadAgentsAsync();
    }
}
