@page "/admin/tenants"
@using QuestFlag.Passport.AdminClient
@inject PassportAdminClient AdminClient

<PageTitle>Tenants — Passport Admin</PageTitle>

<div class="max-w-7xl mx-auto p-4 space-y-6">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center">
        <h1 class="text-2xl font-extrabold tracking-tight text-gray-900 mb-4 sm:mb-0">Tenants</h1>
        <div class="flex space-x-2">
            <input @bind="_searchQuery" @bind:event="oninput" placeholder="Search tenants..." class="input-field w-64" />
            <button class="btn btn-primary" @onclick="() => _showCreate = true">+ New Tenant</button>
        </div>
    </div>

    if (_showCreate)
    {
        <div class="card p-6 bg-blue-50/30 border-blue-100">
            <h2 class="text-lg font-semibold mb-4">Create Tenant</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                <div><label class="block text-sm font-medium text-gray-700 mb-1">Name</label><input @bind="_newName" placeholder="Acme Corp" class="input-field" /></div>
                <div><label class="block text-sm font-medium text-gray-700 mb-1">Slug</label><input @bind="_newSlug" placeholder="acme" class="input-field" /></div>
                <div><label class="block text-sm font-medium text-gray-700 mb-1">Custom Domain</label><input @bind="_newDomain" placeholder="acme.questflag.com" class="input-field" /></div>
                <div><label class="block text-sm font-medium text-gray-700 mb-1">Subdomain Slug</label><input @bind="_newSubSlug" placeholder="acme" class="input-field" /></div>
            </div>
            @if (_createError != null) { <div class="bg-red-50 text-red-600 p-3 rounded-md text-sm border border-red-200 mt-4">@_createError</div> }
            <div class="mt-4 flex space-x-2">
                <button class="btn btn-primary" @onclick="CreateTenant" disabled="@_creating">@(_creating ? "Creating…" : "Create")</button>
                <button class="btn btn-secondary" @onclick="() => _showCreate = false">Cancel</button>
            </div>
        </div>
    }

    @if (_editingTenant != null)
    {
        <div class="card p-6 bg-amber-50/30 border-amber-100">
            <h2 class="text-lg font-semibold mb-4">Edit Tenant: <span class="text-amber-700">@_editingTenant.Name</span></h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
                <div><label class="block text-sm font-medium text-gray-700 mb-1">Name</label><input @bind="_editName" class="input-field" /></div>
                <div><label class="block text-sm font-medium text-gray-700 mb-1">Slug</label><input @bind="_editSlug" class="input-field" /></div>
                <div><label class="block text-sm font-medium text-gray-700 mb-1">Custom Domain</label><input @bind="_editDomain" class="input-field" /></div>
                <div><label class="block text-sm font-medium text-gray-700 mb-1">Subdomain Slug</label><input @bind="_editSubSlug" class="input-field" /></div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
                    <select @bind="_editIsActive" class="input-field">
                        <option value="true">Active</option>
                        <option value="false">Inactive</option>
                    </select>
                </div>
            </div>
            @if (_editError != null) { <div class="bg-red-50 text-red-600 p-3 rounded-md text-sm border border-red-200 mt-4">@_editError</div> }
            <div class="mt-4 flex space-x-2">
                <button class="btn btn-primary" @onclick="UpdateTenant" disabled="@_updating">@(_updating ? "Saving…" : "Save Changes")</button>
                <button class="btn btn-secondary" @onclick="() => _editingTenant = null">Cancel</button>
            </div>
        </div>
    }

    @if (_tenants == null)
    {
        <p class="text-sm font-medium text-gray-500">Loading tenants…</p>
    }
    else
    {
        <div class="card overflow-x-auto">
            <table class="w-full text-left">
                <thead class="table-header"><tr><th class="px-4 py-3">Name</th><th class="px-4 py-3">Slug</th><th class="px-4 py-3">Custom Domain</th><th class="px-4 py-3">Status</th><th class="px-4 py-3">Actions</th></tr></thead>
                <tbody class="divide-y divide-gray-100">
                @foreach (var t in FilteredTenants ?? Array.Empty<TenantAdminDto>())
                {
                    <tr class="hover:bg-gray-50 transition-colors">
                        <td class="table-cell"><a href="/admin/tenants/@t.Id/users" class="text-primary hover:underline font-medium">@t.Name</a></td>
                        <td class="table-cell"><code class="text-xs bg-gray-100 text-gray-800 px-1.5 py-0.5 rounded">@t.Slug</code></td>
                        <td class="table-cell">@(t.CustomDomain ?? t.SubdomainSlug ?? "—")</td>
                        <td class="table-cell"><span class="badge @(t.IsActive ? "badge-success" : "badge-default")">@(t.IsActive ? "Active" : "Inactive")</span></td>
                        <td class="table-cell">
                            <div class="flex items-center space-x-3">
                                <a href="/admin/tenants/@t.Id/users" class="text-sm font-medium text-primary hover:text-primary-hover transition-colors">Users</a>
                                <button class="text-sm font-medium text-amber-600 hover:text-amber-700" @onclick="() => StartEdit(t)">Edit</button>
                                <button class="text-sm font-medium text-red-600 hover:text-red-700" @onclick="() => DeleteTenant(t.Id)">Delete</button>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>

