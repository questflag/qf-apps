@inherits LayoutComponentBase

<AuthorizeView>
    <Authorized>
        <LayoutView Layout="typeof(AuthenticatedLayout)">
            @Body
        </LayoutView>
    </Authorized>
    <NotAuthorized>
        <LayoutView Layout="typeof(AnonymousLayout)">
            @Body
        </LayoutView>
    </NotAuthorized>
</AuthorizeView>
