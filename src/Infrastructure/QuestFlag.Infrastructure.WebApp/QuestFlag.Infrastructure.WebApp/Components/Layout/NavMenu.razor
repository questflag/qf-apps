<div class="px-6 py-4 border-b border-gray-100 mb-4">
    <a class="text-lg font-bold text-blue-600 tracking-tight" href="">QuestFlag Portal</a>
</div>

<nav class="mt-2 flex-1 px-4 space-y-1 bg-white" aria-label="Sidebar">
    <div class="space-y-1">
        <NavLink class="group flex items-center px-3 py-2 text-sm font-medium rounded-md transition-all duration-200" href="" Match="NavLinkMatch.All" ActiveClass="bg-blue-50 text-blue-700 shadow-sm" @onclick="() => {}">
            <span class="bi bi-house-door mr-3 text-lg opacity-70 group-hover:opacity-100" aria-hidden="true"></span>
            <span>Home</span>
        </NavLink>

        <NavLink class="group flex items-center px-3 py-2 text-sm font-medium rounded-md text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition-all duration-200" href="upload" ActiveClass="bg-blue-50 text-blue-700 shadow-sm">
            <span class="bi bi-upload mr-3 text-lg opacity-70 group-hover:opacity-100" aria-hidden="true"></span>
            <span>Upload Files</span>
        </NavLink>

        <NavLink class="group flex items-center px-3 py-2 text-sm font-medium rounded-md text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition-all duration-200" href="uploads" ActiveClass="bg-blue-50 text-blue-700 shadow-sm">
            <span class="bi bi-list mr-3 text-lg opacity-70 group-hover:opacity-100" aria-hidden="true"></span>
            <span>My Uploads</span>
        </NavLink>
    </div>

    <div class="pt-4 mt-4 border-t border-gray-100">
        <AuthorizeView>
            <Authorized>
                <NavLink class="group flex items-center px-3 py-2 text-sm font-medium rounded-md text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition-all duration-200" href="profile" ActiveClass="bg-blue-50 text-blue-700 shadow-sm">
                    <span class="bi bi-person mr-3 text-lg opacity-70 group-hover:opacity-100" aria-hidden="true"></span>
                    <span>My Profile</span>
                </NavLink>

                <div class="mt-4">
                    <form action="/account/logout" method="post">
                        <AntiforgeryToken />
                        <button type="submit" class="group flex w-full items-center px-3 py-2 text-sm font-medium rounded-md text-red-600 hover:bg-red-50 hover:text-red-700 transition-all duration-200">
                            <span class="bi bi-box-arrow-right mr-3 text-lg opacity-70 group-hover:opacity-100" aria-hidden="true"></span>
                            <span>Sign Out</span>
                        </button>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="mt-4">
                    <a class="group flex items-center px-3 py-2 text-sm font-medium rounded-md text-blue-600 hover:bg-blue-50 hover:text-blue-700 transition-all duration-200" href="/login">
                        <span class="bi bi-key mr-3 text-lg opacity-70 group-hover:opacity-100" aria-hidden="true"></span>
                        <span>Sign In (SSO)</span>
                    </a>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</nav>
